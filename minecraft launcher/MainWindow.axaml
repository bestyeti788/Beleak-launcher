<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="minecraft_launcher.MainWindow"
        Width="1200"
        Height="760"
        MinWidth="1000"
        MinHeight="650"
        Title="Beleak Launcher"
        Background="#050608">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#121A24"/>
            <Setter Property="BorderBrush" Value="#263244"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#1A2431"/>
        </Style>

        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#0D1117"/>
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#22C55E"/>
            <Setter Property="BorderBrush" Value="#4ADE80"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#34D399"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#243042"/>
        </Style>

        <Style Selector="Border.glass">
            <Setter Property="Background" Value="#B310131A"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="Border.soft">
            <Setter Property="Background" Value="#12FFFFFF"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>

        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#273447"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#273447"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.Background>
            <ImageBrush Source="C:\Users\Besty\source\repos\minecraft launcher\minecraft launcher\asset\the-most-beautiful-image-ive-ever-taken-in-minecraft-whats-v0-1w8gehosf2hf1.png"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Border Background="#9A000000"/>

        <Grid Margin="20" RowDefinitions="Auto,*">

            <!-- Top bar -->
            <Border Classes="glass" Padding="16">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="14" Background="#1FFFFFFF">
                            <TextBlock Text="⛏"
                                       FontSize="26"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Beleak Launcher"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Offline"
                                       Classes="subtitle"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                        <Button Content="Dossier" Classes="secondary" Click="OpenFolderButton_Click"/>
                        <Button Content="Paramètres" Classes="secondary" Click="SettingsButton_Click"/>
                        <Button Content="Quitter" Classes="secondary" Click="QuitButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main -->
            <Grid Grid.Row="1" Margin="0,18,0,0" ColumnDefinitions="280,*">

                <!-- Left panel -->
                <Border Classes="glass" Padding="18" Margin="0,0,16,0">
                    <StackPanel Spacing="20">

                        <TextBlock Text="Menu" Classes="section"/>

                        <Border Classes="soft" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Compte" Classes="section"/>
                                <TextBlock x:Name="AccountNameText" Text="gamer123" FontSize="16" Foreground="White"/>
                                <TextBlock x:Name="StatusText" Text="Prêt." Classes="subtitle" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="soft" Padding="10">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Version" Classes="section"/>
                                <ComboBox x:Name="VersionComboBox" Width="200"/>
                                <TextBlock Text="Choisis la version à lancer."
                                           Classes="subtitle"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Right content -->
                <Grid Grid.Column="1" RowDefinitions="*,Auto">

                    <Border Classes="glass" Padding="18">
                        <Grid ColumnDefinitions="2*,*" RowDefinitions="Auto,*">
                            <StackPanel Grid.ColumnSpan="2" Spacing="4">
                                <TextBlock Text="Bienvenue" Classes="title"/>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,16,12,0"
                                    Classes="soft"
                                    Padding="18">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Lancement" Classes="section"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Pseudo actif" Classes="subtitle"/>
                                        <TextBlock x:Name="ActivePseudoText"
                                                   Text="gamer123"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Version active" Classes="subtitle"/>
                                        <TextBlock x:Name="ActiveVersionText"
                                                   Text="1.20.4"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="RAM" Classes="subtitle"/>
                                        <TextBlock x:Name="ActiveRamText"
                                                   Text="4096 MB"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                    </StackPanel>

                                    <ProgressBar x:Name="ProgressBar"
                                                 Height="16"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="0"/>

                                    <Button Content="Lancer maintenant"
                                            Classes="primary"
                                            Height="52"
                                            Click="PlayButton_Click"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="12,16,0,0"
                                    Classes="soft"
                                    Padding="18">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Infos" Classes="section"/>
                                    <TextBlock Text="• Design plus sobre et immersif" Classes="subtitle"/>
                                  
                                    <TextBlock Text="• minecraft vanilla" Classes="subtitle"/>
                                    <TextBlock Text="• Lancement rapide" Classes="subtitle"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Bottom action bar -->
                    <Border Grid.Row="1"
                            Classes="glass"
                            Padding="16"
                            Margin="0,16,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock
                            Text="Fait à partir de Avalonia UI."
                                       Classes="subtitle"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Modifier le pseudo"
                                    Classes="secondary"
                                    Click="SettingsButton_Click"/>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>
        </Grid>

        <!-- Settings overlay -->
        <Border x:Name="SettingsOverlay"
                Background="#C0000000"
                IsVisible="False">
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="520">
                <Border Classes="glass" Padding="20">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Paramètres" Classes="section"/>
                                <TextBlock Text="Change le pseudo et la RAM du launcher."
                                           Classes="subtitle"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Fermer"
                                    Classes="secondary"
                                    Click="CloseSettingsButton_Click"/>
                        </Grid>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Pseudo" Classes="subtitle"/>
                            <TextBox x:Name="PseudoTextBox"
                                     Watermark="Nouveau pseudo"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="RAM (MB)" Classes="subtitle"/>
                            <TextBox x:Name="RamTextBox"
                                     Watermark="4096"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Enregistrer"
                                    Classes="primary"
                                    Click="SaveSettingsButton_Click"/>
                            <Button Content="Annuler"
                                    Classes="secondary"
                                    Click="CloseSettingsButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>